{
    "name": "pacyworld/opnsense-mcp",
    "description": "Multi-instance OPNsense MCP server for AI-assisted firewall management",
    "type": "project",
    "license": "BSD-2-Clause",
    "authors": [
        {
            "name": "Daniel Morante",
            "email": "daniel@morante.net"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mcp\\": "classes/Mcp/",
            "OPNsense\\": "classes/OPNsense/"
        },
        "classmap": [
            "tools/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
